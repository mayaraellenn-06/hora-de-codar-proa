programa {
  funcao inicio() {
   inteiro area
    inteiro lado
    

    escreva ("Digite um valor para a base do Quadrado: ")
    leia (lado)
    escreva ("Digite um valor para o lado: ")
    leia (lado)
    area = lado * lado
   escreva (area)

    escreva("A área da figura é igual a: " + area + "²")
 
  }
}
