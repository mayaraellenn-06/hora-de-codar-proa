programa {
  funcao inicio() {
    cadeia nome_do_usuario
    
    escreva ("Olá, como vai? Qual é o seu nome? ")
    leia (nome_do_usuario)

    escreva ("Olá," + nome_do_usuario + "! É um prazer em te conhecer, agora me diga, qual é a sua idade?")
    leia ("idade")
    escreva ("Obrigado pelas informações, até a próxima!" + nome_do_usuario) 
  }
}
