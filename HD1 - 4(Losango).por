programa {
  funcao inicio() {
     inteiro area
    inteiro diagonal_maior 
    inteiro diagonal_menor 

    escreva ("Digite um valor para a area do Losango: ")
    leia (area)
    escreva ("Digite um valor para a diagonal maior: ")
    leia (diagonal_maior)
    escreva ("Digite um valor para a diagonal_menor: ")
    leia (diagonal_menor)

    (diagonal_maior * diagonal_menor)/2 

    escreva("A área da figura é igual a: " + area)

  }
  }
}
