programa {
  funcao inicio() {
       inteiro area 
    inteiro base
    inteiro altura

    escreva("Digite um valor para base do Retângulo: " )
    leia (base)
    escreva("Digite um valor para altura do Retângulo: " )
    leia (altura)
    escreva (area)

    area = base * altura/2

    escreva("A área da figura é igual a: " + area)
  }
  }
}
