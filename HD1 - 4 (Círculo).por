programa {
  funcao inicio() {
     inteiro area
    real pi
    inteiro raio 

    escreva ("Digite um valor para area: ")
    leia (area)
    escreva ("Digite um valor para pi: ")
    leia (pi)
    escreva ("Digite um valor para o raio: ")
    leia (raio)

    area = pi * raio 
    escreva ("O valor da figura é: " + area)

    
  }
}
